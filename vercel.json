{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ],
  "buildCommand": "cd frontend && npm install && npx --yes vite build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd backend && npm install"
}
